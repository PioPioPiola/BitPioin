{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",      
    "jsx": "react-jsx",
    "allowJs": true,                   
    "checkJs": false,                  
    "strict": true,                   
    "noEmit": true,                    
    "skipLibCheck": true,              
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}